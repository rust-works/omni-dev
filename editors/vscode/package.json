{
  "name": "omni-dev",
  "displayName": "omni-dev",
  "description": "A live tree view of every repository and git worktree open across all your VS Code windows, fed by the omni-dev daemon; double-click to focus or open a worktree's window.",
  "icon": "media/icon.png",
  "version": "0.5.0",
  "publisher": "rust-works",
  "license": "BSD-3-Clause",
  "repository": {
    "type": "git",
    "url": "https://github.com/rust-works/omni-dev.git",
    "directory": "editors/vscode"
  },
  "bugs": {
    "url": "https://github.com/rust-works/omni-dev/issues"
  },
  "homepage": "https://github.com/rust-works/omni-dev/blob/main/editors/vscode/README.md",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "omniDevWorktrees",
          "title": "Worktrees",
          "icon": "media/worktrees.svg"
        }
      ]
    },
    "views": {
      "omniDevWorktrees": [
        {
          "id": "omniDevWorktrees.tree",
          "name": "Worktrees",
          "contextualTitle": "omni-dev"
        }
      ]
    },
    "commands": [
      {
        "command": "omniDevWorktrees.refresh",
        "title": "Refresh",
        "category": "omni-dev",
        "icon": "$(refresh)"
      },
      {
        "command": "omniDevWorktrees.itemClicked",
        "title": "Open Worktree (internal)",
        "category": "omni-dev"
      },
      {
        "command": "omniDevWorktrees.openWorktree",
        "title": "Open Worktree",
        "category": "omni-dev"
      },
      {
        "command": "omniDevWorktrees.closeWorktree",
        "title": "Close Worktree",
        "category": "omni-dev"
      },
      {
        "command": "omniDevWorktrees.closeWindow",
        "title": "Close Window",
        "category": "omni-dev"
      },
      {
        "command": "omniDevWorktrees.copyDirectory",
        "title": "Copy Directory",
        "category": "omni-dev"
      },
      {
        "command": "omniDevWorktrees.openPullRequest",
        "title": "Open Pull Request…",
        "category": "omni-dev",
        "icon": "$(git-pull-request)"
      },
      {
        "command": "omniDevWorktrees.openPullRequestInBrowser",
        "title": "Open Pull Request in Browser…",
        "category": "omni-dev",
        "icon": "$(link-external)"
      },
      {
        "command": "omniDevWorktrees.moveClaudeSessionHere",
        "title": "Move Claude Session Here",
        "category": "omni-dev"
      },
      {
        "command": "omniDevWorktrees.hideClosedWorktrees",
        "title": "Hide Worktrees Without a Window",
        "category": "omni-dev",
        "icon": "$(eye)"
      },
      {
        "command": "omniDevWorktrees.showClosedWorktrees",
        "title": "Show Worktrees Without a Window",
        "category": "omni-dev",
        "icon": "$(eye-closed)"
      },
      {
        "command": "omniDevWorktrees.enablePolling",
        "title": "Enable PR Polling",
        "category": "omni-dev"
      },
      {
        "command": "omniDevWorktrees.disablePolling",
        "title": "Disable PR Polling",
        "category": "omni-dev"
      },
      {
        "command": "omniDevWorktrees.openClaude",
        "title": "Open Claude Code",
        "category": "omni-dev",
        "icon": "media/claude.svg"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "omniDevWorktrees.itemClicked",
          "when": "false"
        },
        {
          "command": "omniDevWorktrees.openWorktree",
          "when": "false"
        },
        {
          "command": "omniDevWorktrees.closeWorktree",
          "when": "false"
        },
        {
          "command": "omniDevWorktrees.closeWindow",
          "when": "false"
        },
        {
          "command": "omniDevWorktrees.copyDirectory",
          "when": "false"
        },
        {
          "command": "omniDevWorktrees.openPullRequest",
          "when": "false"
        },
        {
          "command": "omniDevWorktrees.openPullRequestInBrowser",
          "when": "false"
        },
        {
          "command": "omniDevWorktrees.moveClaudeSessionHere",
          "when": "false"
        },
        {
          "command": "omniDevWorktrees.hideClosedWorktrees",
          "when": "omniDevWorktrees.showClosed"
        },
        {
          "command": "omniDevWorktrees.showClosedWorktrees",
          "when": "!omniDevWorktrees.showClosed"
        },
        {
          "command": "omniDevWorktrees.enablePolling",
          "when": "false"
        },
        {
          "command": "omniDevWorktrees.disablePolling",
          "when": "false"
        }
      ],
      "view/title": [
        {
          "command": "omniDevWorktrees.refresh",
          "when": "view == omniDevWorktrees.tree",
          "group": "navigation@1"
        },
        {
          "command": "omniDevWorktrees.hideClosedWorktrees",
          "when": "view == omniDevWorktrees.tree && omniDevWorktrees.showClosed",
          "group": "navigation@2"
        },
        {
          "command": "omniDevWorktrees.showClosedWorktrees",
          "when": "view == omniDevWorktrees.tree && !omniDevWorktrees.showClosed",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "omniDevWorktrees.openWorktree",
          "when": "view == omniDevWorktrees.tree && viewItem =~ /worktree/",
          "group": "0_open@1"
        },
        {
          "command": "omniDevWorktrees.enablePolling",
          "when": "view == omniDevWorktrees.tree && viewItem =~ /^repo\\.github\\.polling-off/ && omniDevWorktrees.showPullRequests && omniDevWorktrees.prStatusSource != webhook",
          "group": "1_pr@0"
        },
        {
          "command": "omniDevWorktrees.disablePolling",
          "when": "view == omniDevWorktrees.tree && viewItem =~ /^repo\\.github\\.polling-on/ && omniDevWorktrees.showPullRequests && omniDevWorktrees.prStatusSource != webhook",
          "group": "1_pr@0"
        },
        {
          "command": "omniDevWorktrees.openPullRequest",
          "when": "view == omniDevWorktrees.tree && viewItem =~ /github/",
          "group": "1_pr@1"
        },
        {
          "command": "omniDevWorktrees.openPullRequestInBrowser",
          "when": "view == omniDevWorktrees.tree && viewItem =~ /github/",
          "group": "1_pr@2"
        },
        {
          "command": "omniDevWorktrees.moveClaudeSessionHere",
          "when": "view == omniDevWorktrees.tree && viewItem =~ /worktree/ && !listMultiSelection",
          "group": "2_session@1"
        },
        {
          "command": "omniDevWorktrees.copyDirectory",
          "when": "view == omniDevWorktrees.tree && viewItem =~ /^(repo|worktree)/",
          "group": "3_copy@1"
        },
        {
          "command": "omniDevWorktrees.closeWindow",
          "when": "view == omniDevWorktrees.tree && viewItem =~ /worktree\\.(current|open)\\./",
          "group": "9_close@1"
        },
        {
          "command": "omniDevWorktrees.closeWorktree",
          "when": "view == omniDevWorktrees.tree && viewItem =~ /worktree\\..*linked/",
          "group": "9_close@2"
        }
      ],
      "editor/title": [
        {
          "command": "omniDevWorktrees.openClaude",
          "group": "navigation@9"
        }
      ]
    },
    "configuration": {
      "title": "omni-dev",
      "properties": {
        "omniDevWorktrees.socketPath": {
          "type": "string",
          "default": "",
          "markdownDescription": "Override the omni-dev daemon control socket path (mirrors the daemon's `--socket`). Leave empty to use the computed default: `<data_dir>/omni-dev/daemon.sock`."
        },
        "omniDevWorktrees.heartbeatSeconds": {
          "type": "number",
          "default": 10,
          "minimum": 1,
          "markdownDescription": "Seconds between heartbeats to the daemon. The daemon reaps a window after a 30s silence, so keep this well under 30."
        },
        "omniDevWorktrees.showPullRequests": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Show each worktree's open GitHub pull request (number, draft, and CI-checks status) in the tree. Resolved by the omni-dev daemon, which runs the GitHub CLI (`gh`) for you and keeps CI state live in every window — so it needs `gh` installed and `gh auth login`; without it, badges are silently omitted. Disable to hide them."
        },
        "omniDevWorktrees.claudeCommand": {
          "type": "string",
          "default": "claude",
          "markdownDescription": "Command run in the terminal opened by the **Open Claude Code** title-bar button (default `claude`). A shell prefix is allowed, e.g. `proxy && claude`."
        },
        "omniDevWorktrees.prStatusSource": {
          "type": "string",
          "enum": ["poll", "webhook"],
          "enumDescriptions": [
            "Resolve PR/CI badges with the daemon's GraphQL poller (the default). ~Free and works for any repo.",
            "Drive badges in real time from a webhook buffer for repos you own, with a low-cadence reconcile poll as the fallback. Requires a deployed buffer (deploy/webhook-buffer/) and an installed webhook on each owned repo; other repos fall back to the reconcile poll."
          ],
          "default": "poll",
          "scope": "application",
          "markdownDescription": "Which live source resolves the PR/CI badges (#1384). `poll` (default) uses the daemon's GraphQL poller. `webhook` drives badges in real time from a webhook buffer for repos **you own** — it requires a deployed buffer (`deploy/webhook-buffer/`) and a webhook installed on each owned repo (`omni-dev daemon webhook register`); repos without a webhook fall back to a low-cadence reconcile poll. In `webhook` mode the per-repo **Enable/Disable PR Polling** controls are hidden, since there is no poll volume to manage. The daemon is the authority, so this applies to every window."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "compile-tests": "tsc -p tsconfig.json",
    "test": "npm run compile-tests && node --test out/",
    "package": "vsce package --no-dependencies",
    "publish:vsce": "vsce publish --no-dependencies",
    "publish:ovsx": "ovsx publish"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.75.0",
    "@vscode/vsce": "^3.2.0",
    "esbuild": "^0.24.0",
    "ovsx": "^0.10.12",
    "typescript": "^5.6.0"
  }
}
