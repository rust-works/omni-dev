{
  "name": "omni-dev",
  "displayName": "omni-dev",
  "description": "A live tree view of every repository and git worktree open across all your VS Code windows, fed by the omni-dev daemon; double-click to focus or open a worktree's window.",
  "icon": "media/icon.png",
  "version": "0.4.0",
  "publisher": "rust-works",
  "license": "BSD-3-Clause",
  "repository": {
    "type": "git",
    "url": "https://github.com/rust-works/omni-dev.git",
    "directory": "editors/vscode"
  },
  "bugs": {
    "url": "https://github.com/rust-works/omni-dev/issues"
  },
  "homepage": "https://github.com/rust-works/omni-dev/blob/main/editors/vscode/README.md",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "omniDevWorktrees",
          "title": "Worktrees",
          "icon": "media/worktrees.svg"
        }
      ]
    },
    "views": {
      "omniDevWorktrees": [
        {
          "id": "omniDevWorktrees.tree",
          "name": "Worktrees",
          "contextualTitle": "omni-dev"
        }
      ]
    },
    "commands": [
      {
        "command": "omniDevWorktrees.refresh",
        "title": "Refresh",
        "category": "omni-dev",
        "icon": "$(refresh)"
      },
      {
        "command": "omniDevWorktrees.open",
        "title": "Open in VS Code",
        "category": "omni-dev"
      },
      {
        "command": "omniDevWorktrees.itemClicked",
        "title": "Open Worktree (internal)",
        "category": "omni-dev"
      },
      {
        "command": "omniDevWorktrees.closeWorktree",
        "title": "Close Worktree",
        "category": "omni-dev"
      },
      {
        "command": "omniDevWorktrees.closeWindow",
        "title": "Close Window",
        "category": "omni-dev"
      },
      {
        "command": "omniDevWorktrees.openPullRequest",
        "title": "Open Pull Request…",
        "category": "omni-dev",
        "icon": "$(git-pull-request)"
      },
      {
        "command": "omniDevWorktrees.hideClosedWorktrees",
        "title": "Hide Worktrees Without a Window",
        "category": "omni-dev",
        "icon": "$(eye)"
      },
      {
        "command": "omniDevWorktrees.showClosedWorktrees",
        "title": "Show Worktrees Without a Window",
        "category": "omni-dev",
        "icon": "$(eye-closed)"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "omniDevWorktrees.itemClicked",
          "when": "false"
        },
        {
          "command": "omniDevWorktrees.open",
          "when": "false"
        },
        {
          "command": "omniDevWorktrees.closeWorktree",
          "when": "false"
        },
        {
          "command": "omniDevWorktrees.closeWindow",
          "when": "false"
        },
        {
          "command": "omniDevWorktrees.openPullRequest",
          "when": "false"
        },
        {
          "command": "omniDevWorktrees.hideClosedWorktrees",
          "when": "omniDevWorktrees.showClosed"
        },
        {
          "command": "omniDevWorktrees.showClosedWorktrees",
          "when": "!omniDevWorktrees.showClosed"
        }
      ],
      "view/title": [
        {
          "command": "omniDevWorktrees.refresh",
          "when": "view == omniDevWorktrees.tree",
          "group": "navigation@1"
        },
        {
          "command": "omniDevWorktrees.hideClosedWorktrees",
          "when": "view == omniDevWorktrees.tree && omniDevWorktrees.showClosed",
          "group": "navigation@2"
        },
        {
          "command": "omniDevWorktrees.showClosedWorktrees",
          "when": "view == omniDevWorktrees.tree && !omniDevWorktrees.showClosed",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "omniDevWorktrees.open",
          "when": "view == omniDevWorktrees.tree && viewItem =~ /worktree/",
          "group": "inline"
        },
        {
          "command": "omniDevWorktrees.openPullRequest",
          "when": "view == omniDevWorktrees.tree && viewItem =~ /github/",
          "group": "1_pr@1"
        },
        {
          "command": "omniDevWorktrees.closeWindow",
          "when": "view == omniDevWorktrees.tree && viewItem =~ /worktree\\.(current|open)\\.main/",
          "group": "9_close@1"
        },
        {
          "command": "omniDevWorktrees.closeWorktree",
          "when": "view == omniDevWorktrees.tree && viewItem =~ /worktree\\..*linked/",
          "group": "9_close@1"
        }
      ]
    },
    "configuration": {
      "title": "omni-dev",
      "properties": {
        "omniDevWorktrees.socketPath": {
          "type": "string",
          "default": "",
          "markdownDescription": "Override the omni-dev daemon control socket path (mirrors the daemon's `--socket`). Leave empty to use the computed default: `<data_dir>/omni-dev/daemon.sock`."
        },
        "omniDevWorktrees.heartbeatSeconds": {
          "type": "number",
          "default": 10,
          "minimum": 1,
          "markdownDescription": "Seconds between heartbeats to the daemon. The daemon reaps a window after a 30s silence, so keep this well under 30."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "compile-tests": "tsc -p tsconfig.json",
    "test": "npm run compile-tests && node --test out/",
    "package": "vsce package --no-dependencies",
    "publish:vsce": "vsce publish --no-dependencies",
    "publish:ovsx": "ovsx publish"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.75.0",
    "@vscode/vsce": "^3.2.0",
    "esbuild": "^0.24.0",
    "ovsx": "^0.10.12",
    "typescript": "^5.6.0"
  }
}
