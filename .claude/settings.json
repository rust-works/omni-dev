{
  "permissions": {
    "allow": [
      "Bash(.claude/hooks/check-snapshots.sh)",
      "Bash(target/debug/omni-dev:*)",
      "Bash(target/release/omni-dev:*)",
      "Bash(target/debug/deps/omni_dev-*:*)",
      "Bash(target/debug/deps/omni_dev:*)",
      "Bash(target/release/deps/omni_dev-*:*)",
      "Bash(target/release/deps/omni_dev:*)",
      "Bash(git diff *)",
      "Bash(ls -la /Users/jky/.claude/plans/ 2>/dev/null | head -5)",
      "Bash(pdftotext *)",
      "Bash(cargo test *)",
      "Bash(cargo clippy *)",
      "Bash(cargo build *)",
      "Bash(cargo fmt *)",
      "Bash(cargo insta *)",
      "Bash(cargo check *)",
      "Bash(cargo llvm-cov *)",
      "Bash(cargo deny check *)",
      "Bash(./scripts/build.sh)",
      "Bash(./scripts/build.sh *)",
      "Bash(omni-dev git commit message view *)",
      "mcp__omni-dev__git_check_commits",
      "Read(//Users/jky/.claude/plans/**)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/format-rust.sh",
            "timeout": 60,
            "statusMessage": "rustfmt"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/check-snapshots.sh",
            "timeout": 30,
            "statusMessage": "snapshot drift check"
          }
        ]
      }
    ]
  }
}
